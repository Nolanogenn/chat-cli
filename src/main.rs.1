use std::{
    io::{BufReader, prelude::*},
    net::{TcpListener, TcpStream},
    time::Duration,
    thread
};
use crossterm::event::*;
use ratatui::*;

fn prompt(text: &str) -> String{
    print!("{}", text);
    std::io::stdout().flush().expect("Oups");
    let mut response = String::new();
    std::io::stdin()
        .read_line(&mut response)
        .expect("failed to get input");
    response.trim_end().to_string()
}

fn main() {
    let username = prompt("give me your username: ");
    let listener = TcpListener::bind("0.0.0.0:7878").unwrap();
    let ip = prompt("what IP are you trying to connect to?");
    println!("trying to connect to: {}", ip);
    let thread_listener = thread::spawn(move || {
        println!("test message\n");
        thread::sleep(Duration::from_millis(500));
    });
    match TcpStream::connect(format!("{}:7878", ip)){ 
        Ok(mut stream) => {
            println!("success");
                loop{
                    let message = prompt("> ");
                    stream.write(&format!("{}: {}", username, message).into_bytes());
                }
        }
        Err(e) => {println!("failed: {}", e); thread::sleep(Duration::from_secs(2))}
    }
    thread_listener.join().unwrap();
}
